# ---------------------------------------------------------------------------
# Copy this file to `.env` (or `.env.local`) and fill in the values.
# Never commit the real `.env` — it is listed in .gitignore.
# ---------------------------------------------------------------------------

# ---- Clerk (authentication) ----
# Get these from https://dashboard.clerk.com → your app → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Clerk JWT issuer domain — from the "convex" JWT template you create in Clerk.
# Looks like: https://<your-app>.clerk.accounts.dev
CLERK_JWT_ISSUER_DOMAIN=https://your-app.clerk.accounts.dev

# Clerk webhook signing secret — from the webhook endpoint you register in Clerk,
# pointing at: <NEXT_PUBLIC_CONVEX_URL-with-.site>/clerk-webhook
CLERK_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Clerk redirects
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/chat
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/chat

# ---- Convex (realtime backend) ----
# Populated automatically by `npx convex dev` the first time you run it.
# Example values:
# CONVEX_DEPLOYMENT=dev:your-deployment-name
# NEXT_PUBLIC_CONVEX_URL=https://your-deployment-name.convex.cloud
CONVEX_DEPLOYMENT=
NEXT_PUBLIC_CONVEX_URL=
